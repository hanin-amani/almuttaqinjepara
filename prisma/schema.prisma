generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

/////////////////////////////////////////////////////
// PUBLIC SCHEMA (APLIKASI RADIO)
/////////////////////////////////////////////////////

model Schedule {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  program_name String
  day          String
  start_time   DateTime @db.Time
  end_time     DateTime @db.Time
  created_at   DateTime @default(now())

  @@map("schedules")
  @@schema("public")
}

model SongRequest {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  song_title String
  message    String?
  status     String   @default("pending")
  created_at DateTime @default(now())

  @@map("song_requests")
  @@schema("public")
}

model ChatMessage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username   String
  message    String
  created_at DateTime @default(now())

  @@map("chat_messages")
  @@schema("public")
}

/////////////////////////////////////////////////////
// SISTEM ARTIKEL / BERITA
/////////////////////////////////////////////////////

model Info {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   @db.Text
  thumbnail   String?
  
  // ✅ TAMBAHAN: Untuk menyimpan kata kunci (comma separated string)
  tags        String?

  status      String   @default("published")
  is_active   Boolean  @default(true)

  category_id String?  @db.Uuid
  author_id   String?  @db.Uuid

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  category    InfoCategory? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  author      Profile?      @relation("AuthorInfo", fields: [author_id], references: [id], onDelete: SetNull)
  
  comments    Comment[]

  @@index([slug])
  @@index([category_id])
  @@map("infos")
  @@schema("public")
}

model InfoCategory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  slug       String   @unique
  created_at DateTime @default(now())

  infos      Info[]

  @@index([slug])
  @@map("info_categories")
  @@schema("public")
}

/////////////////////////////////////////////////////
// SISTEM KOMENTAR (SUARA PEMBACA)
/////////////////////////////////////////////////////

model Comment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  email       String   
  website     String?  
  image       String?  // ✅ TAMBAHKAN INI: Untuk menyimpan URL Avatar/Foto Profil
  content     String   @db.Text
  info_id     String   @db.Uuid
  is_approved Boolean  @default(true)
  
  // Relasi ke User (Jika login)
  user_id     String?  @db.Uuid
  user        User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  // ✅ SISTEM BALASAN (Self-Relation)
  parent_id   String?   @db.Uuid
  parent      Comment?  @relation("CommentReplies", fields: [parent_id], references: [id], onDelete: Cascade)
  replies     Comment[] @relation("CommentReplies")

  // Relasi ke Artikel/Warta
  info        Info      @relation(fields: [info_id], references: [id], onDelete: Cascade)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([info_id])
  @@index([parent_id])
  @@map("comments")
  @@schema("public")
}

/////////////////////////////////////////////////////
// AUTHENTICATION (NEXT-AUTH MODELS)
/////////////////////////////////////////////////////

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  accounts      Account[]
  sessions      Session[]
  comments      Comment[]

  @@map("users")
  @@schema("public")
}

model Account {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String  @db.Uuid
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("public")
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("public")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("public")
}

/////////////////////////////////////////////////////
// ADMIN & STATISTIK
/////////////////////////////////////////////////////

model Admin {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email       String   @unique
  password    String
  role        String   @default("admin")
  last_login  DateTime?
  created_at  DateTime @default(now())

  @@map("admins")
  @@schema("public")
}

model Listener {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  joined_at DateTime @default(now())

  @@map("listeners")
  @@schema("public")
}

model Profile {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role       String   @default("penyiar")
  created_at DateTime @default(now())

  infos      Info[] @relation("AuthorInfo")

  @@map("profiles")
  @@schema("public")
}