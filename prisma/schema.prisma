generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "auth"]
}

/////////////////////////////////////////////////////
// PUBLIC SCHEMA (APLIKASI RADIO)
/////////////////////////////////////////////////////

model Schedule {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  program_name String
  day          String
  start_time   DateTime @db.Time
  end_time     DateTime @db.Time
  created_at   DateTime @default(now())

  @@map("schedules")
  @@schema("public")
}

model SongRequest {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  song_title String
  message    String?
  status     String   @default("pending")
  created_at DateTime @default(now())

  @@map("song_requests")
  @@schema("public")
}

model Info {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title      String
  slug       String   @unique
  thumbnail  String?
  excerpt    String?  @db.Text
  content    String   @db.Text
  category   String   @default("Umum")
  status     String   @default("draft")
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  @@map("infos")
  @@schema("public")
}

model Admin {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String   @unique
  password   String
  role       String   @default("admin")
  last_login DateTime?
  created_at DateTime @default(now())

  @@map("admins")
  @@schema("public")
}

model Listener {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  joined_at DateTime @default(now())

  @@map("listeners")
  @@schema("public")
}

model Profile {
  id         String   @id @db.Uuid
  role       String   @default("penyiar")
  created_at DateTime @default(now())

  user       User @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("profiles")
  @@schema("public")
}

/////////////////////////////////////////////////////
// AUTH SCHEMA (SUPABASE AUTH)
/////////////////////////////////////////////////////

model User {
  id            String    @id @db.Uuid
  email         String?   @db.VarChar(255)
  role          String?   @db.VarChar(255)
  created_at    DateTime? @db.Timestamptz(6)

  profiles Profile?

  @@map("users")
  @@schema("auth")
}