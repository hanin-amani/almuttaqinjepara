generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

/////////////////////////////////////////////////////
// PUBLIC SCHEMA (APLIKASI RADIO)
/////////////////////////////////////////////////////

model Schedule {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  program_name String
  day          String
  start_time   DateTime @db.Time
  end_time     DateTime @db.Time
  created_at   DateTime @default(now())

  @@map("schedules")
  @@schema("public")
}

model SongRequest {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  song_title String
  message    String?
  status     String   @default("pending")
  created_at DateTime @default(now())

  @@map("song_requests")
  @@schema("public")
}

/////////////////////////////////////////////////////
// SISTEM ARTIKEL / BERITA
/////////////////////////////////////////////////////

model Info {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  thumbnail   String?
  status      String   @default("publish")
  is_active   Boolean  @default(true)

  category_id String?  @db.Uuid
  author_id   String?  @db.Uuid

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  category InfoCategory? @relation(fields: [category_id], references: [id])
  author   Profile?      @relation("AuthorInfo", fields: [author_id], references: [id])

  @@index([slug])
  @@index([category_id])
  @@index([author_id])

  @@map("infos")
  @@schema("public")
}

model InfoCategory {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name  String
  slug  String @unique

  infos Info[]

  @@map("info_categories")
  @@schema("public")
}

/////////////////////////////////////////////////////
// ADMIN LOGIN
/////////////////////////////////////////////////////

model Admin {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String    @unique
  password   String
  role       String    @default("admin")
  last_login DateTime?
  created_at DateTime  @default(now())

  @@map("admins")
  @@schema("public")
}

/////////////////////////////////////////////////////
// STATISTIK PENDENGAR RADIO
/////////////////////////////////////////////////////

model Listener {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  joined_at DateTime @default(now())

  @@map("listeners")
  @@schema("public")
}

/////////////////////////////////////////////////////
// PROFIL PENYIAR / AUTHOR
/////////////////////////////////////////////////////

model Profile {
  id         String   @id @db.Uuid
  role       String   @default("penyiar")
  created_at DateTime @default(now())

  infos Info[] @relation("AuthorInfo")

  @@map("profiles")
  @@schema("public")
}

